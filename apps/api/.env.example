# Copy to .env for local dev (apps/api/.env)
NODE_ENV=development
PORT=8080

# Matches docker-compose.yml. On Railway, set to the Railway Postgres URL.
DATABASE_URL=postgres://okes:okes@localhost:55432/okes

# Generate a strong secret for production (min 16 chars), e.g. `openssl rand -hex 32`
JWT_SECRET=dev-only-secret-change-me-please
